# Supabase / PostgreSQL
# Use connection pooling URL (porta 6543) para DATABASE_URL
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Use direct URL (porta 5432) para migrations
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"

# NextAuth — gere com: openssl rand -base64 32
NEXTAUTH_SECRET="seu-secret-aqui"
NEXTAUTH_URL="https://x1pay.vercel.app"

# App
NEXT_PUBLIC_APP_URL="https://x1pay.vercel.app"

# Pagar.me
PAGARME_SECRET_KEY="sk_live_..."
PAGARME_WEBHOOK_SECRET=

# Push (gerado em Configurações > Notificações)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
